# Ignore source control metadata
.git
.gitignore

# Ignore dependency directories (install them inside the container instead)
node_modules/
vendor/

# Ignore local environment secrets and configuration
.env
*.local

# Ignore build artifacts and log files
dist/
build/
*.log
npm-debug.log*

# Ignore OS metadata and IDE settings
.DS_Store
.vscode/
.idea/

# Ignore the Docker files themselves (optional)
Dockerfile
docker-compose.yml
appspec.yml
buildspec.yml
jenkinsfile
scripts/* # If you have build scripts that are only relevant for local development